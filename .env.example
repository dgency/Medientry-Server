NODE_ENV="production"
HOST="0.0.0.0"
PORT="5000"

# Local development example:
# PUBLIC_BASE_URL="http://localhost:5000"
# CLIENT_URL="http://localhost:3000"
# ADMIN_URL="http://localhost:5173"
# CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Public HTTPS origin for this API, used when generating absolute upload URLs.
PUBLIC_BASE_URL="https://api.example.com"

# PostgreSQL connection string for Prisma.
DATABASE_URL="postgresql://postgres:REPLACE_WITH_STRONG_DB_PASSWORD@db.example.internal:5432/medientry_cms"

# Long random secret, at least 32 characters.
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
JWT_EXPIRES_IN="12h"
JWT_REMEMBER_EXPIRES_IN="14d"
AUTH_COOKIE_NAME="medientry_access_token"

# Public frontend and admin dashboard origins. Use HTTPS in production.
CLIENT_URL="https://www.example.com"
ADMIN_URL="https://admin.example.com"

# Optional extra allowed origins, comma-separated, only if needed.
CORS_ORIGINS="https://www.example.com,https://admin.example.com"

# Keep MAIL_ENABLED=false until the SMTP values below are real production values
# and the connection has been verified successfully in the target environment.
MAIL_ENABLED="false"
MAIL_HOST="smtp.example.com"
MAIL_PORT="587"
MAIL_SECURE="false"
MAIL_REQUIRE_TLS="true"
MAIL_USER="smtp-user@example.com"
MAIL_PASS="replace-with-smtp-password-or-provider-api-key"
MAIL_FROM_NAME="Medientry"
MAIL_FROM_EMAIL="no-reply@example.com"
MAIL_REPLY_TO="support@example.com"
MAIL_CONNECTION_TIMEOUT_MS="10000"
MAIL_GREETING_TIMEOUT_MS="10000"
MAIL_SOCKET_TIMEOUT_MS="20000"

BCRYPT_SALT_ROUNDS="10"

# Bootstrap super-admin account. While SEED_SUPER_ADMIN_PASSWORD remains set,
# the server will upsert this account and reset its password on every boot.
# Use a strong temporary bootstrap password, then remove it from long-lived
# production runtime env if you do not want boot-time password reconciliation.
SEED_SUPER_ADMIN_NAME="Super Admin"
SEED_SUPER_ADMIN_EMAIL="admin@example.com"
SEED_SUPER_ADMIN_PASSWORD="change-this-before-seeding"
