# Production example: keep HTTPS origins in deployed environments.
# API base URL for the admin dashboard. Use the production API origin and include /api.
VITE_API_BASE_URL=https://api.example.com/api

# Public site origin for cross-links back to the website.
VITE_CLIENT_URL=https://www.example.com

# Local development example: use plain HTTP on localhost.
# VITE_API_BASE_URL=http://localhost:5000/api
# VITE_CLIENT_URL=http://localhost:3000
