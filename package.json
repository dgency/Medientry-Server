{
  "name": "medientry-server",
  "version": "1.0.0",
  "description": "Production-ready Node.js, Express, TypeScript, Prisma, and PostgreSQL backend for Medientry.",
  "main": "dist/server.js",
  "scripts": {
    "predev": "npm run prisma:generate && prisma migrate deploy",
    "dev": "concurrently -k -n api,admin -c green,magenta \"npm run dev:api\" \"npm run dev:admin\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:admin": "npm --prefix admin-dashboard run dev",
    "build": "tsc",
    "start": "node dist/server.js",
    "dashboard:dev": "npm --prefix admin-dashboard run dev",
    "dashboard:build": "npm --prefix admin-dashboard run build",
    "dashboard:preview": "npm --prefix admin-dashboard run preview",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "prisma:seed": "prisma db seed",
    "seed": "tsx prisma/seed.ts",
    "seed:content": "tsx prisma/seedExistingContent.ts"
  },
  "keywords": [
    "express",
    "typescript",
    "prisma",
    "postgresql",
    "medientry"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "9.0.1",
    "prisma": "^6.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
