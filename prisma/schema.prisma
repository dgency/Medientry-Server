generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SimpleStatus {
  ACTIVE
  INACTIVE
}

enum PageType {
  HOME
  ABOUT
  CONTACT
  STUDY_DESTINATION
  MEDICAL_COLLEGE
  BLOG
  NOTICE
  SUCCESS_STORY
  CUSTOM
}

enum PageTemplateType {
  DEFAULT
  DESTINATION
  COLLEGE
  LANDING
}

enum StudyDestinationTemplateType {
  FIXED_FRONTEND_CONTENT
  DYNAMIC_TEMPLATE
}

enum GalleryItemType {
  IMAGE
  VIDEO
}

model User {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  email     String     @unique
  password  String
  role      UserRole   @default(ADMIN)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([role, status])
  @@map("users")
}

model RevokedAccessToken {
  id        String   @id @default(uuid()) @db.Uuid
  jti       String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime
  revokedAt DateTime @default(now())
  reason    String?

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("revoked_access_tokens")
}

model SiteSetting {
  id             String   @id @default(uuid()) @db.Uuid
  logoLight      String?
  logoDark       String?
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  textColor      String?
  favicon        String?
  contactEmail   String?
  phone          String?
  address        String?
  socialLinks    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("site_settings")
}

model Page {
  id             String            @id @default(uuid()) @db.Uuid
  title          String
  slug           String            @unique
  pageType       PageType          @default(CUSTOM)
  templateType   PageTemplateType  @default(DEFAULT)
  status         PublicationStatus @default(DRAFT)
  heroTitle      String?
  heroSubtitle   String?
  heroImage      String?
  content        Json?
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]          @default([])
  ogImage        String?
  canonicalUrl   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([pageType, status])
  @@index([status, updatedAt])
  @@map("pages")
}

model StudyDestination {
  id               String                       @id @default(uuid()) @db.Uuid
  title            String
  slug             String                       @unique
  country          String
  shortDescription String?
  featuredImage    String?
  content          Json?
  isFeatured       Boolean                      @default(false)
  showInMenu       Boolean                      @default(false)
  sortOrder        Int                          @default(0)
  status           PublicationStatus            @default(DRAFT)
  templateType     StudyDestinationTemplateType @default(DYNAMIC_TEMPLATE)
  seoTitle         String?
  seoDescription   String?
  seoKeywords      String[]                     @default([])
  ogImage          String?
  canonicalUrl     String?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  medicalColleges  MedicalCollege[]

  /// Use FIXED_FRONTEND_CONTENT for MBBS in Bangladesh so the existing design
  /// stays unchanged and only CMS-driven content and images are editable.
  /// Use DYNAMIC_TEMPLATE for reusable destinations like MBBS in Georgia.
  @@index([country, status])
  @@index([isFeatured, sortOrder])
  @@index([showInMenu, sortOrder])
  @@map("study_destinations")
}

model MedicalCollege {
  id                 String            @id @default(uuid()) @db.Uuid
  studyDestinationId String?           @db.Uuid
  name               String
  slug               String            @unique
  country            String
  city               String?
  shortDescription   String?
  featuredImage      String?
  gallery            Json?
  tuitionFee         Decimal?          @db.Decimal(12, 2)
  hostelFee          Decimal?          @db.Decimal(12, 2)
  totalFee           Decimal?          @db.Decimal(12, 2)
  ranking            String?
  eligibility        String?
  admissionProcess   Json?
  facilities         Json?
  content            Json?
  isFeatured         Boolean           @default(false)
  sortOrder          Int               @default(0)
  status             PublicationStatus @default(DRAFT)
  seoTitle           String?
  seoDescription     String?
  seoKeywords        String[]          @default([])
  ogImage            String?
  canonicalUrl       String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  studyDestination   StudyDestination? @relation(fields: [studyDestinationId], references: [id], onDelete: SetNull)
  feeInquiries       CollegeFeeInquiry[]

  @@index([studyDestinationId])
  @@index([country, city])
  @@index([isFeatured, status, sortOrder])
  @@map("medical_colleges")
}

model CollegeFeeInquiry {
  id                        String         @id @default(uuid()) @db.Uuid
  medicalCollegeId          String?        @db.Uuid
  fullName                  String
  phoneNumber               String
  emailAddress              String?
  country                   String?
  preferredStudyDestination String?
  interestedCollegeName     String
  message                   String?
  source                    String         @default("College Fee Inquiry")
  sourcePage                String?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  medicalCollege            MedicalCollege? @relation(fields: [medicalCollegeId], references: [id], onDelete: SetNull)

  @@index([medicalCollegeId])
  @@index([createdAt])
  @@map("college_fee_inquiries")
}

model ConsultationLead {
  id               String   @id @default(uuid()) @db.Uuid
  fullName         String
  userRole         String
  whatsappNumber   String
  phoneNumber      String
  emailAddress     String?
  passingYear      String
  neetScore        String?
  stateName        String
  preferredCollege String?
  message          String?
  sourcePage       String?
  submissionDate   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt])
  @@index([phoneNumber, createdAt])
  @@map("consultation_leads")
}

model GalleryItem {
  id        String          @id @default(uuid()) @db.Uuid
  title     String
  type      GalleryItemType
  url       String
  thumbnail String?
  category  String?
  sortOrder Int             @default(0)
  status    SimpleStatus    @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([type, status])
  @@index([category, sortOrder])
  @@map("gallery_items")
}

model HomeReel {
  id              String       @id @default(uuid()) @db.Uuid
  title           String
  thumbnail       String?
  wistiaVideoId   String?
  wistiaEmbedCode String?
  sortOrder       Int          @default(0)
  status          SimpleStatus @default(ACTIVE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status, sortOrder])
  @@map("home_reels")
}

model Blog {
  id             String            @id @default(uuid()) @db.Uuid
  title          String
  slug           String            @unique
  excerpt        String?
  featuredImage  String?
  content        Json?
  category       String?
  author         String?
  isPinned       Boolean           @default(false)
  status         PublicationStatus @default(DRAFT)
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]          @default([])
  ogImage        String?
  canonicalUrl   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([category, status])
  @@index([isPinned, status, createdAt])
  @@map("blogs")
}

model Notice {
  id             String            @id @default(uuid()) @db.Uuid
  title          String
  slug           String            @unique
  description    String?
  fileUrl        String?
  isPinned       Boolean           @default(false)
  pinnedOrder    Int?              @unique
  status         PublicationStatus @default(DRAFT)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]          @default([])
  ogImage        String?
  canonicalUrl   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, publishedAt])
  @@index([isPinned, publishedAt])
  @@map("notices")
}

model SuccessStory {
  id          String       @id @default(uuid()) @db.Uuid
  studentName String
  roleType    String       @default("Student")
  country     String?
  city        String?
  university  String?
  batch       String?
  image       String?
  rating      Int?
  reviewText  String?
  fullStory   String?
  videoUrl    String?
  showOnHomepage Boolean   @default(true)
  status      SimpleStatus @default(ACTIVE)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, showOnHomepage, sortOrder])
  @@index([country])
  @@map("success_stories")
}

model HomeSectionSetting {
  id              String   @id @default(uuid()) @db.Uuid
  sectionKey      String   @unique
  eyebrow         String?
  title           String?
  subtitle        String?
  content         Json?
  selectedItemIds Json?
  itemLimit       Int?
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("home_section_settings")
}
